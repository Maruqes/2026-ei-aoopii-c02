meta {
  name: Create Transcription
  type: http
  seq: 2
}

post {
  url: {{base_url}}/v1/transcriptions
  body: multipartForm
  auth: none
}

body:multipart-form {
  recording_filename: {{recording_filename}}
  discord_id: {{discord_id}}
  username: {{username}}
  display_name: {{display_name}}
  channel_name: {{channel_name}}
  recording_started_at: {{recording_started_at}}
}

tests {
  test("transcription request succeeds", function() {
    expect(res.status).to.equal(200);
  });

  test("response includes persisted messages and chunks", function() {
    expect(res.body).to.have.property("status", "accepted");
    expect(res.body).to.have.property("recording_filename");
  });
}
