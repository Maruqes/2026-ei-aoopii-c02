POSTGRES_DB=discord_anthropologist
POSTGRES_USER=discord
POSTGRES_PASSWORD=discord
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

DATABASE_URL=postgresql://discord:discord@127.0.0.1:5433/discord_anthropologist
WHISPER_MODEL=base
WHISPER_DEVICE=auto
PYTORCH_CUDA_INDEX_URL=https://download.pytorch.org/whl/cu126
MAX_UPLOAD_BYTES=262144000
UPLOAD_TMP_DIR=.tmp/uploads
RECORDINGS_DIR=discord_bot/recordings
KEEP_UPLOADS=false

TRANSCRIPTION_API_URL=http://localhost:8000
TRANSCRIPTION_API_TIMEOUT=10m
DISCORD_SUMMARY_CHANNEL_ID=1501613714477023233
SESSION_SUMMARY_TIMEOUT=15m

LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:2b

PROFILE_DOCS_PROVIDER=local
LOCAL_PROFILE_DIR=/app/profiles
