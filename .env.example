POSTGRES_DB=discord_anthropologist
POSTGRES_USER=discord
POSTGRES_PASSWORD=discord
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

DATABASE_URL=postgresql://discord:discord@127.0.0.1:5433/discord_anthropologist

# Transcription provider: whisper (local/default) or speechmatics (hosted).
TRANSCRIPTION_PROVIDER=whisper

WHISPER_MODEL=large-v3
# Use cpu without an NVIDIA driver. Use cuda to enable docker-compose.gpu.yml via make.
WHISPER_DEVICE=cpu
# Keep Portuguese fixed for Discord calls. Set auto to let Whisper detect the language.
WHISPER_LANGUAGE=pt
WHISPER_BEAM_SIZE=10
WHISPER_INITIAL_PROMPT=
WHISPER_CARRY_INITIAL_PROMPT=false
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
WHISPER_HALLUCINATION_SILENCE_THRESHOLD=2.0
WHISPER_MAX_NO_SPEECH_PROB=0.8
WHISPER_NUM_THREADS=0
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
PYTORCH_CUDA_INDEX_URL=https://download.pytorch.org/whl/cu126

# Used when TRANSCRIPTION_PROVIDER=speechmatics.
SPEECHMATICS_API_KEY=your_speechmatics_api_key
SPEECHMATICS_API_KEY_01=
SPEECHMATICS_API_KEY_02=
SPEECHMATICS_API_KEY_03=
SPEECHMATICS_BATCH_URL=https://eu1.asr.api.speechmatics.com/v2
SPEECHMATICS_LANGUAGE=multi
SPEECHMATICS_MODEL=melia-1
SPEECHMATICS_POLLING_INTERVAL_SECONDS=2
SPEECHMATICS_TIMEOUT_SECONDS=600
SPEECHMATICS_SEGMENT_GAP_SECONDS=1.5
SPEECHMATICS_ADDITIONAL_VOCAB=
SPEECHMATICS_USAGE_LIMIT_HOURS=50

UPLOAD_TMP_DIR=.tmp/uploads
RECORDINGS_DIR=discord_bot/recordings
KEEP_UPLOADS=false

# Discord Developer Portal: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token
DISCORD_APP_ID=your_discord_application_id
# Minutes before the bot leaves the call and starts processing. Use 0 to disable.
BOT_LEAVE=60
TRANSCRIPTION_API_URL=http://localhost:8000

# LLM provider: openai, groq, or ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: use these values when LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: local LLM configuration when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:2b

PROFILE_DOCS_PROVIDER=local
LOCAL_PROFILE_DIR=/app/profiles
