POSTGRES_DB=discord_anthropologist
POSTGRES_USER=discord
POSTGRES_PASSWORD=discord
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

DATABASE_URL=postgresql://discord:discord@127.0.0.1:5433/discord_anthropologist
WHISPER_MODEL=base
# Use cpu without an NVIDIA driver. Use cuda to enable docker-compose.gpu.yml via make.
WHISPER_DEVICE=cpu
# Keep Portuguese fixed for Discord calls. Set auto to let Whisper detect the language.
WHISPER_LANGUAGE=pt
# Beam search trades speed for recognition quality. Set 0 to use Whisper's Python default.
WHISPER_BEAM_SIZE=5
# Optional vocabulary/context hint, for example names, project terms, and acronyms.
WHISPER_INITIAL_PROMPT=
WHISPER_CARRY_INITIAL_PROMPT=false
# Set false if long transcriptions get stuck repeating bad text.
WHISPER_CONDITION_ON_PREVIOUS_TEXT=true
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
# Used only when WHISPER_DEVICE=cuda.
PYTORCH_CUDA_INDEX_URL=https://download.pytorch.org/whl/cu126
UPLOAD_TMP_DIR=.tmp/uploads
RECORDINGS_DIR=discord_bot/recordings
KEEP_UPLOADS=false

# Discord Developer Portal: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token
DISCORD_APP_ID=your_discord_application_id
# Minutes before the bot leaves the call and starts processing. Use 0 to disable.
BOT_LEAVE=60
TRANSCRIPTION_API_URL=http://localhost:8000
TRANSCRIPTION_API_TIMEOUT=10m
SESSION_SUMMARY_TIMEOUT=15m

# LLM provider: openai, groq, or ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: use these values when LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: local LLM configuration when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:2b

PROFILE_DOCS_PROVIDER=local
LOCAL_PROFILE_DIR=/app/profiles
